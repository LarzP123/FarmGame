<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="FarmGame" />
		<Option pch_mode="2" />
		<Option compiler="gcc" />
		<Build>
			<Target title="Debug">
				<Option output="bin/Debug/FarmGame" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Debug/" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-g" />
				</Compiler>
			</Target>
			<Target title="Release">
				<Option output="bin/Release/FarmGame" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Release/" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-O2" />
				</Compiler>
				<Linker>
					<Add option="-s" />
				</Linker>
			</Target>
		</Build>
		<Compiler>
			<Add option="-pedantic-errors" />
			<Add option="-Wall" />
			<Add option="-std=c89 -pedantic-errors" />
		</Compiler>
		<Unit filename="src/adjustfarmsetup.c">
			<Option compilerVar="CC" />
			<Option compile="0" />
			<Option link="0" />
		</Unit>
		<Unit filename="src/charbitmap.c">
			<Option compilerVar="CC" />
			<Option compile="0" />
			<Option link="0" />
		</Unit>
		<Unit filename="src/fileswindows.c">
			<Option compilerVar="CC" />
			<Option compile="0" />
			<Option link="0" />
		</Unit>
		<Unit filename="src/gfx.c">
			<Option compilerVar="CC" />
			<Option compile="0" />
			<Option link="0" />
		</Unit>
		<Unit filename="src/gfxlinux.c">
			<Option compilerVar="CC" />
			<Option compile="0" />
			<Option link="0" />
		</Unit>
		<Unit filename="src/gfxwindows.c">
			<Option compilerVar="CC" />
			<Option compile="0" />
			<Option link="0" />
		</Unit>
		<Unit filename="src/initfarmsetup.c">
			<Option compilerVar="CC" />
			<Option compile="0" />
			<Option link="0" />
		</Unit>
		<Unit filename="src/pack.c">
			<Option compilerVar="CC" />
			<Option link="0" />
			<Option compiler="gcc" use="1" buildCommand='gcc -std=c90 &quot;$file&quot; &quot;obj\Debug\utilswindows.obj&quot; -o obj\Debug\pack.exe' />
		</Unit>
		<Unit filename="src/startgame.c">
			<Option compilerVar="CC" />
			<Option link="0" />
			<Option weight="70" />
			<Option compiler="gcc" use="1" buildCommand="compilehelpers\wslbuild.bat $file obj/Debug/main $object" />
		</Unit>
		<Unit filename="src/utilslinux.asm">
			<Option compilerVar="CC" />
			<Option link="0" />
			<Option compiler="gcc" use="1" buildCommand='nasm -f elf64 -DLINUX &quot;$file&quot; -o obj\Debug\utilslinux.obj' />
		</Unit>
		<Unit filename="src/utilswindows.asm">
			<Option compilerVar="CC" />
			<Option link="0" />
			<Option compiler="gcc" use="1" buildCommand='nasm -f win64 &quot;$file&quot; -o obj\Debug\utilswindows.obj' />
		</Unit>
		<Extensions>
			<lib_finder disable_auto="1" />
		</Extensions>
	</Project>
</CodeBlocks_project_file>
